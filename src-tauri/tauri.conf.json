{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SimNation Radio",
  "version": "0.1.9",
  "identifier": "com.simnationradio.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:8000",
    "frontendDist": "https://simnationradio.com"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SimNation Radio",
        "width": 1280,
        "height": 720,
        "decorations": false,
        "transparent": false,
        "visible": true
      },
      {
        "label": "overlay",
        "title": "SNR Smart Overlay",
        "url": "/overlay",
        "width": 450,
        "height": 450,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/MiselTwister/simnation-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "RWQtTnuT6Gd8InO0+gezacnObpb2AQwvYvoNnwOTOPiyFUXVBIGd3t0"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}