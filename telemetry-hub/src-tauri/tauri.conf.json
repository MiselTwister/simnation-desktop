{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SimNation Hub",
  "version": "1.1.3",
  "identifier": "com.simnation.hub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SimNation Telemetry HUD",
        "width": 1400,
        "height": 100,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "radio_panel",
        "title": "SimNation Radio",
        "url": "https://simnationradio.com",
        "width": 1280,
        "height": 720,
        "decorations": false,
        "transparent": false,
        "visible": true,
        "center": true
      },
      {
        "label": "radio_overlay",
        "title": "SNR Smart Overlay",
        "url": "https://simnationradio.com/overlay",
        "width": 600,
        "height": 450,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/MiselTwister/simnation-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU2RkRGNjMwMjczRTA0MzEKUldReEJENG5NUGI5VnM5a1JBMStuMFFiWVJicnNTTWkzVE50M2dpTUk5U2lFaGJQL1pyVkVCckoK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/scs-telemetry.dll"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}